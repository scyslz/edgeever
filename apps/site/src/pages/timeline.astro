---
import { getCollection } from "astro:content";
import { Picture } from "astro:assets";
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
import Sectionhead from "@/components/sectionhead.astro";
import ProductTimeline from "@/components/ProductTimeline.astro";
import { productTimeline } from "@/data/productTimeline";

// Filter blog entries with 'draft: false' & date before current date
const publishedBlogEntries = await getCollection("blog", ({ data }) => {
  return !data.draft && data.publishDate < new Date();
});

// Sort content entries by publication date
publishedBlogEntries.sort(function (a, b) {
  return b.data.publishDate.valueOf() - a.data.publishDate.valueOf();
});
---

<Layout title="开发日志">
  <Container>
    <Sectionhead>
      <Fragment slot="title">产品演进时间轴</Fragment>
      <Fragment slot="desc">
        基于同级 `edgeever` 核心仓库的真实 Git 提交历史整理，按日期合并产品能力、部署体验和迁移流程的变化。
      </Fragment>
    </Sectionhead>

    <main class="mt-16 mx-auto max-w-5xl">
      <section>
        <ProductTimeline items={productTimeline} />
      </section>

      <section class="mt-20">
        <div class="max-w-2xl">
          <p class="text-sm font-semibold text-brand-text">同步文档</p>
          <h2 class="mt-2 text-3xl font-bold tracking-tight text-slate-950">部署、迁移与产品说明</h2>
          <p class="mt-3 leading-7 text-slate-600">
            这些文章继续保留为可分享的独立页面，内容同样以核心仓库 README 和 docs 为准。
          </p>
        </div>
      </section>

      <ul class="mt-10 grid gap-8 md:grid-cols-3">
        {
          publishedBlogEntries.map((blogPostEntry, index) => (
            <li class="rounded-lg border border-slate-100 bg-white shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
              <a href={`/timeline/${blogPostEntry.slug}`} class="block h-full">
                <div>
                  <Picture
                    src={blogPostEntry.data.image.src}
                    alt={blogPostEntry.data.image.alt}
                    sizes="(max-width: 800px) 100vw, 800px"
                    width={800}
                    height={600}
                    loading={index <= 2 ? "eager" : "lazy"}
                    decoding={index <= 2 ? "sync" : "async"}
                    class="aspect-[4/3] w-full rounded-t-lg object-cover object-center bg-white"
                  />
                  <div class="p-5">
                    <span class="text-xs font-semibold uppercase tracking-wider text-brand-text">
                      {blogPostEntry.data.category}
                    </span>

                    <h3 class="mt-2 text-xl font-semibold leading-snug tracking-tight text-slate-950">
                      {blogPostEntry.data.title}
                    </h3>
                    <p class="mt-3 line-clamp-3 text-sm leading-6 text-slate-500">
                      {blogPostEntry.data.snippet}
                    </p>

                    <div class="mt-5 flex gap-2 text-sm">
                      <span class="text-gray-400">
                        {blogPostEntry.data.author}
                      </span>
                      <span class="text-gray-400">• </span>
                      <time
                        class="text-gray-400"
                        datetime={blogPostEntry.data.publishDate.toISOString()}>
                        {blogPostEntry.data.publishDate.toDateString()}
                      </time>
                    </div>
                  </div>
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </main>
  </Container>
</Layout>
