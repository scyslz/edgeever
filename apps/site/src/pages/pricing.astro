---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
import Sectionhead from "@/components/sectionhead.astro";
import PricingCard from "@/components/pricing.astro";

const pricing = [
  {
    name: "个人自托管",
    price: "接近 $0",
    popular: true,
    features: [
      "基于 Cloudflare Workers、D1 和 R2",
      "README 估算：短笔记可达 10 万条量级",
      "README 估算：200KB 图片约可存放 5 万张",
      "Web 端图片压缩可减少 R2 资源占用",
      "REST API、OpenAPI、CLI 与 Remote MCP 均可使用",
      "适合个人笔记、迁移旧资料和 AI Agent 读取整理"
    ],
    button: {
      text: "查看部署仓库",
      link: "https://github.com/msh01/edgeever",
    },
  },
  {
    name: "超出免费额度后",
    price: "按 Cloudflare 计费",
    popular: false,
    features: [
      "费用由你的 Cloudflare 账号计划和用量决定",
      "大量图片、附件或高频 API 调用会增加资源消耗",
      "多实例可通过 EDGE_EVER_INSTANCE 和作用域变量隔离",
      "自定义域名可通过 EDGE_EVER_CUSTOM_DOMAIN 配置",
      "部署前可运行 bun run deploy:doctor 检查配置",
      "具体单价请以 Cloudflare 官方定价页为准"
    ],
    button: {
      text: "查看 Cloudflare 定价",
      link: "https://www.cloudflare.com/zh-cn/developer-platform/products/",
    },
  },
];
---

<Layout title="托管费用">
  <Container>
    <Sectionhead>
      <Fragment slot="title">极低的使用与托管成本</Fragment>
      <Fragment slot="desc">
        EdgeEver 本身是开源项目。官网不替 Cloudflare 承诺价格，以下只同步核心仓库 README 对个人使用规模的说明；实际账单以您的 Cloudflare 账号计划、资源用量和官方定价为准。
      </Fragment>
    </Sectionhead>

    <div
      class="grid md:grid-cols-2 gap-10 mx-auto max-w-4xl mt-16 pb-12">
      {pricing.map((item) => <PricingCard plan={item} />)}
    </div>
  </Container>
</Layout>
