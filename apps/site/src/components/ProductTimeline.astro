---
interface TimelineItem {
  date: string;
  title: string;
  summary: string;
  commits: string[];
  highlights: string[];
}

interface Props {
  items: TimelineItem[];
}

const { items } = Astro.props;
---

<ol class="relative border-s border-slate-200">
  {
    items.map((item, index) => (
      <li class:list={["ms-6", index === items.length - 1 ? "mb-0" : "mb-10"]}>
        <span class="absolute -start-3 flex h-6 w-6 items-center justify-center rounded-full border border-brand-border bg-brand-soft ring-8 ring-white">
          <span class="h-2.5 w-2.5 rounded-full bg-brand"></span>
        </span>
        <div class="rounded-lg border border-slate-100 bg-white p-5 shadow-sm transition hover:border-brand-border/50 hover:shadow-md md:p-6">
          <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
            <div>
              <time class="text-sm font-semibold leading-none text-brand-text" datetime={item.date}>
                {item.date}
              </time>
              <h2 class="mt-2 text-2xl font-bold tracking-tight text-slate-950">{item.title}</h2>
            </div>
            <p class="shrink-0 rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-500">
              {item.commits.length} 个代表提交
            </p>
          </div>

          <p class="mt-4 text-base leading-7 text-slate-600">{item.summary}</p>

          <div class="mt-5 flex flex-wrap gap-2">
            {item.highlights.map((highlight) => (
              <span class="rounded-full border border-brand-border/40 bg-brand-soft px-3 py-1 text-xs font-medium text-brand-text">
                {highlight}
              </span>
            ))}
          </div>

          <div class="mt-5 flex flex-wrap items-center gap-2 text-xs text-slate-400">
            <span>相关提交</span>
            {item.commits.map((commit) => (
              <code class="rounded bg-slate-100 px-1.5 py-0.5 font-mono text-slate-600">{commit}</code>
            ))}
          </div>
        </div>
      </li>
    ))
  }
</ol>
