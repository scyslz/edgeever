---
import { Picture } from "astro:assets";
import heroImage from "@/assets/hero.png";
import Link from "@/components/ui/link.astro";
import { Icon } from "astro-icon/components";
---

<main class="relative grid lg:grid-cols-2 place-items-center pt-16 pb-12 md:pt-24 md:pb-28 overflow-hidden">
  <div class="py-6 md:order-2 hidden md:block relative group">
    <div class="relative border border-brand-border/20 rounded-lg p-2 bg-white shadow-xl transition-transform duration-500 group-hover:scale-[1.01]">
      <Picture
        src={heroImage}
        alt="EdgeEver - Cloudflare-native note-taking workspace"
        widths={[200, 400, 600]}
        sizes="(max-width: 800px) 100vw, 620px"
        loading="eager"
        format="avif"
        class="rounded-xl shadow-inner border border-slate-100"
      />
    </div>
  </div>

  <div class="md:order-1 relative z-10">
    <div class="inline-flex items-center gap-2 px-3 py-1 text-xs font-semibold text-brand-text bg-brand-soft border border-brand-border/40 rounded-full mb-6">
      <span class="flex h-2 w-2 rounded-full bg-brand animate-pulse"></span>
      开源、自托管、Cloudflare-native
    </div>
    
    <h1 class="text-5xl lg:text-6xl xl:text-7xl font-bold tracking-tight text-slate-900 leading-tight">
      EdgeEver
      <span class="block mt-2 text-4xl lg:text-5xl xl:text-6xl text-slate-700">把经典印象笔记体验部署到自己的 Cloudflare</span>
    </h1>
    
    <h2 class="text-xl lg:text-2xl font-semibold text-slate-700 mt-4 flex items-center gap-2">
      <span class="text-lg lg:text-xl font-normal text-slate-500">三栏笔记、开放数据、REST API、OpenAPI 与 Remote MCP</span>
    </h2>
    
    <p class="text-lg mt-6 text-slate-600 max-w-xl leading-relaxed">
      EdgeEver 是一个现代笔记工作区：保留笔记本树、笔记列表、主编辑区的熟悉工作流，把笔记正文存入 Cloudflare D1，把图片和附件存入 R2。它提供富文本编辑、PWA、离线草稿队列、客户端图片压缩，并让 AI Agent 通过 MCP 读取和整理你的个人笔记。
    </p>
    
    <div class="mt-8 flex flex-col sm:flex-row gap-4">
      <Link
        href="https://github.com/msh01/edgeever"
        target="_blank"
        class="flex gap-2 items-center justify-center shadow-lg shadow-brand/20 hover:shadow-brand/35 transition-all duration-300 hover:scale-[1.02]"
        rel="noopener">
        <Icon class="text-white w-5 h-5" name="bx:bxl-github" />
        查看 GitHub 仓库
      </Link>
      <Link
        size="lg"
        style="outline"
        rel="noopener"
        href="https://demo.edgeever.org"
        class="flex gap-2 items-center justify-center hover:bg-slate-50 transition-colors"
        target="_blank">
        <Icon class="text-slate-700 w-5 h-5" name="bx:bx-show" />
        访问在线演示
      </Link>
      <a
        rel="noopener"
        href="/timeline/ai-agent-deploy-cloudflare"
        class="flex gap-2 items-center justify-center px-6 py-3 border border-slate-200 hover:border-slate-300 rounded-lg text-slate-600 hover:text-slate-900 transition-all text-sm font-medium"
        >
        <Icon class="text-slate-600 w-5 h-5" name="bx:bxs-bot" />
        AI Agent 部署
      </a>
    </div>
  </div>
</main>
